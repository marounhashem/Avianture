generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  CREW
  HANDLER
}

enum CrewRole {
  PIC
  SIC
  FA
}

enum FlightStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ServiceType {
  FUEL
  GPU
  CATERING
  TRANSPORT
  PARKING
  CUSTOMS
}

enum ServiceStatus {
  PENDING
  ACKNOWLEDGED
  IN_PROGRESS
  COMPLETED
  NOT_REQUIRED
}

model Operator {
  id        String       @id @default(cuid())
  name      String
  createdAt DateTime     @default(now())
  users     User[]
  flights   Flight[]
  crew      CrewMember[]
  handlers  Handler[]
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  passwordHash  String
  name          String
  role          Role
  operatorId    String?
  operator      Operator?          @relation(fields: [operatorId], references: [id])
  handlerId     String?
  handler       Handler?           @relation(fields: [handlerId], references: [id])
  crewMemberId  String?            @unique
  crewMember    CrewMember?        @relation(fields: [crewMemberId], references: [id])
  statusChanges  ServiceStatusLog[]
  messages       FlightMessage[]
  flightViews    UserFlightView[]
  issuesResolved CrewAssignment[]   @relation("IssueResolvedBy")

  // Slice 13: per-user notification preferences (defaults preserve existing behavior)
  notifyOnIssueRaised   Boolean @default(true)
  notifyOnNewMessage    Boolean @default(true)
  notifyOnServiceStatus Boolean @default(true)
  notifyOnIssueResolved Boolean @default(true)
  notifyOnMention       Boolean @default(true)

  createdAt      DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([operatorId])
  @@index([handlerId])
}

model Flight {
  id              String           @id @default(cuid())
  operatorId      String
  operator        Operator         @relation(fields: [operatorId], references: [id])
  tailNumber      String
  aircraftType    String
  originIcao      String
  destIcao        String
  etdUtc          DateTime
  etaUtc          DateTime
  pax             Int
  purpose         String?
  status          FlightStatus     @default(DRAFT)
  crewAssignments CrewAssignment[]
  handlerRequests HandlerRequest[]
  messages        FlightMessage[]
  userViews       UserFlightView[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([operatorId])
  @@index([etdUtc])
}

model CrewMember {
  id          String           @id @default(cuid())
  operatorId  String
  operator    Operator         @relation(fields: [operatorId], references: [id])
  name        String
  role        CrewRole
  user        User?
  assignments CrewAssignment[]
  createdAt   DateTime         @default(now())

  @@index([operatorId])
}

model CrewAssignment {
  id                String     @id @default(cuid())
  flightId          String
  flight            Flight     @relation(fields: [flightId], references: [id], onDelete: Cascade)
  crewMemberId      String
  crewMember        CrewMember @relation(fields: [crewMemberId], references: [id])
  appointedAt       DateTime   @default(now())
  acknowledgedAt    DateTime?
  issue             String?
  issueUpdatedAt    DateTime?
  issueResolvedAt   DateTime?
  issueResolvedById String?
  issueResolvedBy   User?      @relation("IssueResolvedBy", fields: [issueResolvedById], references: [id])
  issueResolution   String?

  @@unique([flightId, crewMemberId])
  @@index([flightId])
}

model Handler {
  id         String           @id @default(cuid())
  operatorId String
  operator   Operator         @relation(fields: [operatorId], references: [id])
  name       String
  company    String?
  email      String?
  phone      String?
  city       String?
  country    String?
  airports   String[]         @default([])
  users      User[]
  requests   HandlerRequest[]
  createdAt  DateTime         @default(now())

  @@index([operatorId])
}

model HandlerRequest {
  id               String           @id @default(cuid())
  flightId         String
  flight           Flight           @relation(fields: [flightId], references: [id], onDelete: Cascade)
  handlerId        String
  handler          Handler          @relation(fields: [handlerId], references: [id])
  airport          String
  inviteToken      String           @unique
  inviteExpiresAt  DateTime
  inviteAcceptedAt DateTime?
  services         ServiceRequest[]
  createdAt        DateTime         @default(now())

  @@index([flightId])
  @@index([handlerId])
  @@index([inviteToken])
}

model ServiceRequest {
  id               String             @id @default(cuid())
  handlerRequestId String
  handlerRequest   HandlerRequest     @relation(fields: [handlerRequestId], references: [id], onDelete: Cascade)
  type             ServiceType
  status           ServiceStatus      @default(PENDING)
  note             String?
  statusLogs       ServiceStatusLog[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([handlerRequestId, type])
  @@index([handlerRequestId])
}

model ServiceStatusLog {
  id                String         @id @default(cuid())
  serviceRequestId  String
  serviceRequest    ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  fromStatus        ServiceStatus
  toStatus          ServiceStatus
  changedAt         DateTime       @default(now())
  changedByUserId   String
  changedBy         User           @relation(fields: [changedByUserId], references: [id])
  // Note captured at the moment of change (operator or handler-supplied).
  // Optional; null means no note was attached to this transition.
  note              String?

  @@index([serviceRequestId])
}

model FlightMessage {
  id        String   @id @default(cuid())
  flightId  String
  flight    Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  @@index([flightId, createdAt])
}

model UserFlightView {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flightId   String
  flight     Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  lastSeenAt DateTime @default(now())

  @@unique([userId, flightId])
  @@index([userId])
  @@index([flightId])
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}
